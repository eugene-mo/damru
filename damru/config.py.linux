"""Damru Linux Configuration Example

Rename this file to `config.py` and replace the existing one 
if you are running Damru natively on a Linux server or desktop.
"""

# Pool Defaults
# "auto" = spin up redroid Docker containers natively on Linux
MODE = "auto"

# Number of concurrent browser instances
NUM_DEVICES = 1
DEVICE = None

# Proxy Configuration
PROXY = None                   
HTTP_PROXY = None              

# WSL2 Configuration (NOT NEEDED FOR NATIVE LINUX)
# These are ignored when running natively, but must be present.
WSL_DISTRO = "Ubuntu"
WSL_USERNAME = ""
WSL_PASSWORD = ""


# MuMu Configuration (NOT SUPPORTED ON LINUX)
# MuMu Player is a Windows-only emulator. These settings are ignored.
MUMU_MANAGER_PATH = None
MUMU_INSTANCE_INDICES = None
MUMU_AUTO_CREATE = False
MUMU_CPU = 2
MUMU_MEMORY_GB = 1
MUMU_STRICT_RESOURCE_LIMIT = True
MUMU_BOOT_FALLBACK_CPU = 2
MUMU_BOOT_FALLBACK_MEMORY_GB = 2
MUMU_SYSTEM_DISK_WRITABLE = True

# Chrome APK Path
# Example absolute Linux path to your custom APK directory
# CHROME_APK = "/opt/damru/chrome-apks/145.0.7632.75"
CHROME_APK = None

# Redroid Container Settings
REDROID_IMAGE = "damru-redroid:latest"
REDROID_BASE_PORT = 5600
REDROID_CONTAINER_PREFIX = "damru-worker-"
REDROID_CPUS = 2.0
REDROID_MEMORY = "2g"
REDROID_GPU_MODE = "guest"  # Change to "host" if you have Linux GPU passthrough setup!
REDROID_SETUPWIZARD_DISABLED = True

# Timeouts & Debug
CONTAINER_BOOT_TIMEOUT = 90
DOCKER_CMD_TIMEOUT = 30
APK_INSTALL_TIMEOUT = 120
SESSION_SETUP_TIMEOUT = 120
MAX_SESSION_RETRIES = 2
HEALTH_CHECK_INTERVAL = 30
MAX_SLOT_FAILURES = 3
DEBUG = False
